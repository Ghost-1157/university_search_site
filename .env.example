# Local Development Configuration
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=practice_for_practice
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
FRONTEND_ORIGIN=*

# For Render Deployment: Render automatically provides DATABASE_URL
# You can also set individual parameters above if needed
# DATABASE_URL=postgresql://user:password@host:port/database
PORT=3000
NODE_ENV=production

# Preferred hosted database connection
DATABASE_URL=postgresql://user:password@host:5432/practice_for_practice
DB_SSL=true

# Local database fallback
DB_HOST=localhost
DB_PORT=5432
DB_NAME=practice_for_practice
DB_USER=postgres
DB_PASSWORD=

# Optional frontend origin when hosting the frontend elsewhere
FRONTEND_ORIGIN=

# Optional table overrides
UNIFIED_UNIVERSITIES_TABLE=university_table_final
UNIVERSITIES_TABLE=university_table_final